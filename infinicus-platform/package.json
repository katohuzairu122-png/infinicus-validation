{
  "name": "infinicus-platform",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "workspace:validate": "node scripts/validate-workspace.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-security": "^4.0.1",
    "turbo": "^2.1.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.64.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-47429",
        "GHSA-f88m-g3jw-g9cj"
      ]
    }
  }
}
