{
  "name": "@infinicus/api",
  "version": "0.0.1",
  "private": true,
  "description": "INFINICUS API server — governed application API (BUILD-21)",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@infinicus/shared-types": "workspace:*",
    "@infinicus/database": "workspace:*",
    "@infinicus/event-contracts": "workspace:*",
    "@infinicus/handoff-contracts": "workspace:*",
    "@infinicus/authentication": "workspace:*",
    "@infinicus/authorization": "workspace:*",
    "@infinicus/onboarding": "workspace:*",
    "@infinicus/workflow": "workspace:*",
    "@infinicus/billing": "workspace:*",
    "@infinicus/configuration": "workspace:*",
    "@infinicus/observability": "workspace:*",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^6.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "zod": "^3.23.0"
  }
