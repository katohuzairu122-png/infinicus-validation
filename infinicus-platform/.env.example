# BUILD-24 — this file is the human-readable mirror of
# packages/configuration/src/secrets.ts's SECRET_INVENTORY, the single
# source of truth for every environment variable server-side code
# actually reads. Keep the two in sync: an entry here with no matching
# SECRET_INVENTORY row (or vice versa) is a real drift bug, not a style
# nit — this file previously listed SUPABASE_*/JWT_SECRET/SENTRY_DSN
# variables that no code in this repository has ever read (a stale
# leftover predating this monorepo's actual configuration schema);
# they have been removed rather than perpetuated.

# ── Database (secret — rotationPolicyDays: 90, owner: platform-database) ──
# Required for the application process to start.
DATABASE_URL=postgresql://app_role:changeme@localhost:5432/infinicus

# Deploy/migration/grant scripts only — never read by the running
# application process. Requires elevated (non-RLS-restricted) privileges.
ADMIN_DATABASE_URL=postgresql://admin_role:changeme@localhost:5432/infinicus

# ── Database (non-secret) ──────────────────────────────────────────
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000

# ── HTTP (non-secret) ───────────────────────────────────────────────
PORT=3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── Observability (non-secret) ─────────────────────────────────────
LOG_LEVEL=info

# ── Platform (non-secret) ──────────────────────────────────────────
NODE_ENV=development
