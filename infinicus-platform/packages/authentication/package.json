{
  "name": "@infinicus/authentication",
  "version": "0.0.1",
  "private": true,
  "description": "Authentication \u2014 password credentials, session lifecycle, service-account API keys",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@infinicus/shared-types": "workspace:*",
    "@infinicus/configuration": "workspace:*",
    "@infinicus/database": "workspace:*",
    "bcryptjs": "^2.4.3"
  }
}
