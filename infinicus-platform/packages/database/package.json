{
  "name": "@infinicus/database",
  "version": "0.0.1",
  "private": true,
  "description": "Database client, schema definitions, and migration utilities",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --reporter=verbose tests/da-repositories.integration.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@infinicus/shared-types": "workspace:*",
    "@infinicus/configuration": "workspace:*",
    "pg": "^8.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.6",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
