{
  "name": "@infinicus/observability",
  "version": "0.0.1",
  "private": true,
  "description": "Structured logging, metrics, tracing, and Sentry integration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@infinicus/shared-types": "workspace:*",
    "@infinicus/configuration": "workspace:*",
    "pino": "^9.0.0"
  }
}
